<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Top Up Saldo - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/qrcode-generator/qrcode.js"></script>
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        <div class="profile-card">
            <h2><i class="fas fa-wallet"></i> Top Up Saldo</h2>
            <p class="topup-subtitle">Masukkan nominal saldo yang ingin Anda isi.</p>
            
            <form id="topUpForm">
                <div class="form-group">
                    <label for="amount">Nominal Top Up</label>
                    <input type="number" id="amount" name="amount" placeholder="Contoh: 50000" min="10000" max="950000" class="form-input" required>
                </div>
                <button type="submit" class="btn btn-success" style="margin-top: 20px;">
                    <i class="fas fa-qrcode"></i> Buat Pembayaran QRIS
                </button>
            </form>
        </div>

        <div class="history-item">
            <div class="history-header" style="cursor: default;">
                <span><i class="fas fa-hourglass-half"></i> Menunggu Pembayaran</span>
            </div>
            <div class="history-details" style="max-height: none; opacity: 1; margin-top: 15px; border-top: 1px solid var(--border-color-light); padding-top: 15px;">
                <div class="table-responsive-wrapper">
                    <table class="deposit-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Jumlah</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="pending-deposits-table-body">
                            <tr><td colspan="4" style="text-align:center;">Memuat data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="qrisModal" class="modal">
        <div class="modal-content" style="max-width: 400px;">
            <div style="text-align: center; margin-bottom: 15px;">
                <h3 style="margin: 0;">Scan QRIS</h3>
                <p style="font-size: 0.9rem; color: var(--text-muted-light);">Scan menggunakan E-Wallet / M-Banking</p>
            </div>

            <div style="display: flex; justify-content: center; margin-bottom: 20px;">
                <div id="qrcode-container" style="padding: 15px; background: #fff; border-radius: 12px; border: 1px solid #e5e7eb;"></div>
            </div>
            
            <ul class="detail-list" style="margin-bottom: 20px;">
                <li>
                    <dt>Jago</dt>
                    <dd>105327562286</dd>
                </li>
                <li>
                    <dt>Seabank</dt>
                    <dd>901889113783</dd>
                </li>
                <li>
                    <dt>ID Transaksi</dt>
                    <dd id="modalTopUpId" style="font-family: monospace;"></dd>
                </li>
                <li>
                    <dt>Total Bayar</dt>
                    <dd id="modalFinalAmount" style="color: var(--primary-color); font-size: 1.1rem;"></dd>
                </li>
            </ul>
            
            <div class="info-box-blue" style="text-align: center; padding: 10px; margin-bottom: 20px;">
                <i class="fas fa-sync fa-spin"></i> Menunggu pembayaran otomatis...
            </div>
            
            <div class="modal-button-container">
                <button type="button" id="cancelPaymentBtn" class="btn btn-danger">Batalkan</button>
                <button type="button" id="closeModalBtn" class="btn btn-secondary">Tutup</button>
            </div>
        </div>
    </div>

    <div id="verificationModal" class="modal">
        <div class="modal-content" style="max-width: 350px; text-align: center;">
            <div style="font-size: 3rem; color: #f59e0b; margin-bottom: 15px;"><i class="fas fa-exclamation-triangle"></i></div>
            <h4>Batalkan Deposit?</h4>
            <p style="margin-bottom: 25px;">Transaksi akan dihapus dan tidak bisa dipulihkan.</p>
            <div class="modal-button-container">
                <button type="button" id="declineCancelBtn" class="btn btn-secondary">Kembali</button>
                <button type="button" id="confirmCancelBtn" class="btn btn-danger">Ya, Batalkan</button>
            </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const topUpForm = document.getElementById('topUpForm');
            const qrisModal = document.getElementById('qrisModal');
            const closeModalBtn = document.getElementById('closeModalBtn');
            const cancelPaymentBtn = document.getElementById('cancelPaymentBtn');
            const tableBody = document.getElementById('pending-deposits-table-body');
            
            const verificationModal = document.getElementById('verificationModal');
            const confirmCancelBtn = document.getElementById('confirmCancelBtn');
            const declineCancelBtn = document.getElementById('declineCancelBtn');

            let pollingInterval = null;

            const formatCurrency = (amount) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);

            // Render Tabel
            const addDepositToTable = (deposit) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><small style="font-family:monospace;">${deposit.top_up_id}</small></td>
                    <td style="font-weight:bold; color:var(--primary-color);">${formatCurrency(deposit.amount)}</td>
                    <td><span class="status-badge status-pending">${deposit.status}</span></td>
                    <td><button class="btn-small btn-view" data-id="${deposit.top_up_id}"><i class="fas fa-eye"></i></button></td>
                `;
                return row;
            };

            // Fetch Data Pending
            const fetchPendingDeposits = async () => {
                try {
                    const response = await fetch('/api/deposits/pending');
                    const deposits = await response.json();
                    tableBody.innerHTML = '';
                    if (deposits.length > 0) {
                        deposits.forEach(deposit => tableBody.appendChild(addDepositToTable(deposit)));
                    } else {
                        tableBody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:20px; color:var(--text-muted-light);">Tidak ada tagihan pending.</td></tr>';
                    }
                } catch (error) {
                    tableBody.innerHTML = '<tr><td colspan="4" style="text-align:center; color:red;">Gagal memuat data.</td></tr>';
                }
            };

            // Polling Status
            const startPolling = (topUpId) => {
                if (pollingInterval) clearInterval(pollingInterval);
                pollingInterval = setInterval(async () => {
                    try {
                        const response = await fetch(`/api/deposit/status/${topUpId}`);
                        if (!response.ok) return;
                        const data = await response.json();
                        if (['SUCCESS', 'success'].includes(data.status)) {
                            clearInterval(pollingInterval);
                            alert('✅ Pembayaran Berhasil Diterima!');
                            closeModal();
                            window.location.reload();
                        }
                    } catch (error) { console.error(error); }
                }, 3000);
            };

            const closeModal = () => {
                if (pollingInterval) clearInterval(pollingInterval);
                qrisModal.style.display = 'none';
                verificationModal.style.display = 'none';
            };

            const showQrisModal = (data) => {
                document.getElementById('modalTopUpId').textContent = data.topUpId;
                document.getElementById('modalFinalAmount').textContent = formatCurrency(data.finalAmount);
                
                const qr = qrcode(0, 'M');
                qr.addData(data.qrisString);
                qr.make();
                document.getElementById('qrcode-container').innerHTML = qr.createImgTag(6, 0); // Cell size 6, margin 0
                
                // Perbaiki tampilan gambar QR agar pas di container
                const img = document.querySelector('#qrcode-container img');
                if(img) { img.style.display = 'block'; img.style.maxWidth = '100%'; img.style.height = 'auto'; }

                qrisModal.style.display = 'block';
                startPolling(data.topUpId);
            };

            // Submit Topup
            topUpForm.addEventListener('submit', async function(event) {
                event.preventDefault();
                const amount = this.elements.amount.value;
                const btn = this.querySelector('button[type="submit"]');
                
                if(amount < 10000 || amount > 950000) return alert('Minimal Rp 10.000 dan Maksimal 950000');

                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';

                try {
                    const response = await fetch('/api/payment/generate-qris', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ baseAmount: amount })
                    });
                    const data = await response.json();
                    if (!response.ok) throw new Error(data.message);
                    
                    await fetchPendingDeposits();
                    showQrisModal(data);
                } catch (error) {
                    alert(error.message);
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-qrcode"></i> Buat Pembayaran QRIS';
                    this.reset();
                }
            });

            // Klik Tombol Lihat
            tableBody.addEventListener('click', async (event) => {
                const btn = event.target.closest('.btn-view');
                if (btn) {
                    const topUpId = btn.dataset.id;
                    btn.disabled = true;
                    try {
                        const response = await fetch(`/api/deposit/details/${topUpId}`);
                        const data = await response.json();
                        if (!response.ok) throw new Error(data.message);
                        showQrisModal(data);
                    } catch (error) {
                        alert(error.message);
                    } finally {
                        btn.disabled = false;
                    }
                }
            });
            
            // Modal Actions
            closeModalBtn.addEventListener('click', closeModal);
            cancelPaymentBtn.addEventListener('click', () => {
                qrisModal.style.display = 'none';
                verificationModal.style.display = 'block';
            });
            declineCancelBtn.addEventListener('click', () => {
                verificationModal.style.display = 'none';
                qrisModal.style.display = 'block';
            });
            
            confirmCancelBtn.addEventListener('click', async () => {
                const topUpId = document.getElementById('modalTopUpId').textContent;
                confirmCancelBtn.disabled = true;
                try {
                    await fetch(`/api/deposit/cancel/${topUpId}`, { method: 'POST' });
                    alert('Dibatalkan.');
                    closeModal();
                    fetchPendingDeposits();
                } catch (e) { alert('Gagal.'); }
                finally { confirmCancelBtn.disabled = false; }
            });

            window.addEventListener('click', (e) => {
                if (e.target == qrisModal || e.target == verificationModal) closeModal();
            });

            fetchPendingDeposits();
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
