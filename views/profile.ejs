<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        <div class="profile-card">
            
            <h2><i class="fas fa-user-cog"></i> Pengaturan Profil</h2>
            <form id="profileForm">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" class="form-input">
                </div>
                <div class="form-group">
                    <label for="phone">Nomor HP</label>
                    <input type="tel" id="phone" name="phone" class="form-input">
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" class="form-input">
                </div>
                <div class="form-group">
                    <label for="telegram">ID Telegram</label>
                    <input type="number" id="telegram" name="telegram" class="form-input" placeholder="Contoh: 123456789">
                </div>

                <div class="form-group">
                    <label for="apikey">API Key</label>
                    <div class="apikey-group">
                        <input type="text" id="apikey" name="apikey" class="form-input" readonly>
                        <button type="button" id="regenerateApiKey" class="icon-btn" title="Ganti API Key"><i class="fas fa-sync-alt"></i></button>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="webhook">URL Webhook (Notifikasi Transaksi)</label>
                    <div class="webhook-group">
                        <input type="url" id="webhook" name="webhook" class="form-input" placeholder="https://domain-anda.com/webhook">
                        <button type="button" id="saveWebhookBtn" class="icon-btn" title="Simpan Webhook"><i class="fas fa-save"></i></button>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 25px;">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Simpan Perubahan Profile
                    </button>
                    
                    <a href="/docs" class="btn btn-info" style="text-decoration: none; text-align: center;">
                        <i class="fas fa-book"></i> Dokumentasi API
                    </a>
                </div>
            </form>

            <hr>

            <h2><i class="fas fa-lock"></i> Ubah Password</h2>
            <form id="passwordForm">
                <div class="form-group">
                    <label for="oldPassword">Password Sebelumnya</label>
                    <input type="password" id="oldPassword" name="oldPassword" class="form-input" required>
                </div>
                <div class="form-group">
                    <label for="newPassword">Password Baru</label>
                    <input type="password" id="newPassword" name="newPassword" class="form-input" required>
                </div>
                <button type="submit" class="btn btn-danger" style="margin-top: 10px;">
                    <i class="fas fa-key"></i> Ubah Password
                </button>
            </form>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const profileForm = document.getElementById('profileForm');
            const passwordForm = document.getElementById('passwordForm');
            const regenerateBtn = document.getElementById('regenerateApiKey');
            const saveWebhookBtn = document.getElementById('saveWebhookBtn');

            document.getElementById('username').value = "<%= user.username %>";
            document.getElementById('phone').value = "<%= user.phone || '' %>";
            document.getElementById('email').value = "<%= user.email %>";
            document.getElementById('telegram').value = "<%= user.telegram || '' %>";
            document.getElementById('apikey').value = "<%= user.apikey %>";
            document.getElementById('webhook').value = "<%= user.webhook || '' %>";

            profileForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(profileForm);
                formData.delete('webhook');
                formData.delete('apikey');
                const data = Object.fromEntries(formData.entries());

                try {
                    const response = await fetch('/api/profile/update', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.message);
                    alert(result.message);
                } catch (error) {
                    alert('Gagal update profil: ' + error.message);
                }
            });

            passwordForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(passwordForm);
                const data = Object.fromEntries(formData.entries());
                try {
                    const response = await fetch('/api/password/update', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.message);
                    alert(result.message);
                    passwordForm.reset();
                } catch (error) {
                    alert('Gagal update password: ' + error.message);
                }
            });

            regenerateBtn.addEventListener('click', () => {
                if (confirm('Yakin ingin ganti API Key? Key lama akan mati.')) {
                    fetch('/api/apikey/regenerate', { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.newApiKey) {
                            document.getElementById('apikey').value = data.newApiKey;
                            alert('API Key diperbarui!');
                        } else {
                            alert('Gagal.');
                        }
                    });
                }
            });
            
            saveWebhookBtn.addEventListener('click', async () => {
                const webhookUrl = document.getElementById('webhook').value;
                if (webhookUrl && !webhookUrl.startsWith('http')) {
                    alert('URL harus diawali http:// atau https://');
                    return;
                }
                try {
                    const response = await fetch('/api/profile/update-webhook', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ webhook: webhookUrl })
                    });
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.message);
                    alert(result.message);
                } catch (error) {
                    alert('Gagal: ' + error.message);
                }
            });
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
