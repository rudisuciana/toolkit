<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-auth.css">
    <link rel="stylesheet" href="/css/style-components.css">
</head>
<body>
    <div class="stars-bg">
        <div class="stars"></div>
        <div class="stars"></div>
        <div class="stars"></div>
    </div>

    <div class="auth-container">
        <h1 class="brand-title">WUZZSTORE</h1>
        <h3 style="margin-bottom: 20px;">Atur Ulang Password Anda</h3>

        <div id="message-display" style="margin-bottom: 15px; font-weight: bold; text-align: center;"></div>

        <form id="resetPasswordForm">
            <input type="hidden" id="token" name="token" value="<%= token %>">
            
            <div class="form-group">
                <label for="newPassword" style="text-align: left;">Password Baru</label>
                <input type="password" id="newPassword" name="newPassword" class="form-input" placeholder="Masukkan password baru" required>
            </div>
            
            <div class="form-group">
                <label for="confirmPassword" style="text-align: left;">Konfirmasi Password Baru</label>
                <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="Ulangi password baru" required>
            </div>
            
            <button type="submit" class="btn">Reset Password</button>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const resetPasswordForm = document.getElementById('resetPasswordForm');
            const messageDisplay = document.getElementById('message-display');
            const submitButton = resetPasswordForm.querySelector('button');

            resetPasswordForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const token = document.getElementById('token').value;
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmPassword').value;

                // Validasi kecocokan password di sisi klien
                if (newPassword !== confirmPassword) {
                    messageDisplay.style.color = '#d9534f';
                    messageDisplay.textContent = 'Password dan konfirmasi password tidak cocok.';
                    return;
                }

                // Ubah status tombol saat loading
                submitButton.disabled = true;
                submitButton.textContent = 'Memproses...';
                messageDisplay.textContent = '';
                messageDisplay.style.color = '';

                try {
                    // Kirim data ke API Backend
                    const response = await fetch('/api/auth/reset-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token, newPassword })
                    });
                    const result = await response.json();

                    if (!response.ok) {
                        throw new Error(result.message || 'Terjadi kesalahan.');
                    }

                    // Sukses
                    messageDisplay.style.color = '#5cb85c';
                    messageDisplay.textContent = result.message;
                    submitButton.style.display = 'none';

                    // Redirect otomatis ke halaman login setelah 3 detik
                    setTimeout(() => {
                        window.location.href = '/login';
                    }, 3000);

                } catch (error) {
                    // Gagal
                    messageDisplay.style.color = '#d9534f';
                    messageDisplay.textContent = 'Error: ' + error.message;
                    submitButton.disabled = false;
                    submitButton.textContent = 'Reset Password';
                }
            });
        });
    </script>
</body>
</html>
