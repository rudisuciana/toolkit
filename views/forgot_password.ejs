<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lupa Password - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-auth.css">
    <link rel="stylesheet" href="/css/style-components.css">
</head>
<body>
    <div class="stars-bg">
        <div class="stars"></div>
        <div class="stars"></div>
        <div class="stars"></div>
    </div>

    <div class="auth-container">
        <h1 class="brand-title">WUZZSTORE</h1>
        <h3 style="margin-bottom: 10px;">Lupa Password</h3>
        <p style="font-size: 0.9rem; margin-bottom: 20px; color: #555;">
            Masukkan alamat email Anda yang terdaftar. Kami akan mengirimkan link untuk mereset password Anda.
        </p>

        <div id="message-display" style="margin-bottom: 15px; font-weight: bold; text-align: center;"></div>

        <form id="forgotPasswordForm">
            <div class="form-group">
                <label for="email" style="text-align: left;">Email</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="email@contoh.com" required>
            </div>
            <button type="submit" class="btn">Kirim Link Reset</button>
        </form>
        
        <p style="margin-top: 15px; font-size: 0.9rem;">
            Ingat password Anda? <a href="/login" style="color: #5c67f2; text-decoration: none; font-weight: bold;">Login di sini</a>
        </p>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const forgotPasswordForm = document.getElementById('forgotPasswordForm');
            const messageDisplay = document.getElementById('message-display');
            const submitButton = forgotPasswordForm.querySelector('button');

            forgotPasswordForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = document.getElementById('email').value;

                // Ubah status tombol saat loading
                submitButton.disabled = true;
                submitButton.textContent = 'Mengirim...';
                messageDisplay.textContent = '';
                messageDisplay.style.color = '';

                try {
                    // Kirim permintaan ke API Backend
                    const response = await fetch('/api/auth/forgot-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email })
                    });
                    const result = await response.json();

                    if (!response.ok) {
                        throw new Error(result.message || 'Terjadi kesalahan.');
                    }
                    
                    // Tampilkan pesan sukses
                    messageDisplay.style.color = '#5cb85c';
                    messageDisplay.textContent = result.message;
                    submitButton.style.display = 'none'; // Sembunyikan tombol agar tidak diklik lagi

                } catch (error) {
                    // Tampilkan pesan error
                    messageDisplay.style.color = '#d9534f';
                    messageDisplay.textContent = 'Error: ' + error.message;
                    submitButton.disabled = false;
                    submitButton.textContent = 'Kirim Link Reset';
                }
            });
        });
    </script>
</body>
</html>
