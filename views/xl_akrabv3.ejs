<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XL Akrab V3 - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        <div class="profile-card">
            <h2><i class="fas fa-users"></i> XL Akrab V3</h2>
            <p class="topup-subtitle">Masukkan nomor XL Anda untuk melihat stok produk.</p>
            
            <div id="message-display" class="tembak-info-box" style="display: none; margin-bottom: 15px;"></div>
            
            <form id="checkAkrabForm" onsubmit="return false;">
                <div class="form-group">
                    <label for="nomorInput">Nomor XL</label>
                    <input type="tel" id="nomorInput" name="number" placeholder="Contoh: 0878..." class="form-input" autocomplete="off" required>
                </div>
            </form>
        </div>

        <div id="products-container" class="profile-card" style="max-width: 900px; display: none; margin-top: 20px;">
            <h3><i class="fas fa-box-open"></i> Daftar Produk</h3>
            <div class="tab-container">
                <button class="tab-button active" data-tab="fresh">Fresh 1</button>
                <button class="tab-button" data-tab="bekasan">Fresh 2</button>
            </div>
            <div id="tab-content">
                <div id="fresh-products" class="tab-pane active"></div>
                <div id="bekasan-products" class="tab-pane"></div>
            </div>
        </div>
    </main>

    <div id="productModal" class="modal">
        <div class="modal-content">
            <span class="modal-close-btn">&times;</span>
            
            <div id="buyView">
                <h3>KONFIRMASI PEMBELIAN</h3>
                <hr style="margin-bottom: 20px; border-color: var(--border-color-light);">
                <form id="buyForm" data-code="">
                    <div class="form-group">
                        <label>Nama Produk</label>
                        <input id="modalNamaProduk" class="form-input" type="text" readonly disabled>
                    </div>
                    <div class="form-group">
                        <label>Nomor Tujuan</label>
                        <input id="modalNomor" class="form-input" type="text" readonly disabled>
                    </div>
                    <div class="form-group">
                        <label>Harga</label>
                        <input id="modalHarga" class="form-input" type="text" readonly disabled style="color: var(--primary-color); font-weight: 700;">
                    </div>
                    <div class="form-group">
                        <label>Rincian Kuota</label>
                        <div id="modalDescription" class="description-box"></div>
                    </div>
                    <div class="modal-button-container">
                        <button type="button" class="btn closeModalBtn btn-danger">Batal</button>
                        <button type="submit" id="buyButton" class="btn btn-success">Beli Sekarang</button>
                    </div>
                </form>
            </div>

            <div id="detailView" style="display: none;">
                <div class="modal-title-container">
                    <h3>DETAIL TRANSAKSI</h3>
                    <div class="loading-line"></div>
                </div>
                <hr style="margin-bottom: 20px; border-color: var(--border-color-light);">
                <form id="detailForm">
                    <div class="form-group"><label>Ref ID</label><input id="detailRefId" class="form-input" readonly disabled></div>
                    <div class="form-group"><label>Nomor</label><input id="detailNomor" class="form-input" readonly disabled></div>
                    <div class="form-group"><label>Produk</label><input id="detailNamaProduk" class="form-input" readonly disabled></div>
                    <div class="form-group"><label>Harga</label><input id="detailHarga" class="form-input" readonly disabled></div>
                    <div class="form-group"><label>Status</label><input id="detailStatus" class="form-input" readonly disabled style="font-weight: bold;"></div>
                    <div class="form-group"><label>Pesan Provider</label><textarea id="detailMessage" class="form-input" readonly disabled rows="2"></textarea></div>
                    <button type="button" class="btn closeModalBtn btn-secondary" style="margin-top: 15px;">Tutup</button>
                </form>
            </div>
        </div>
    </div>
    
    <div id="txErrorModal" class="modal">
        <div class="modal-content">
            <div class="modal-icon" style="color: #d9534f; font-size: 4rem; margin-bottom: 15px;"><i class="fas fa-times-circle"></i></div>
            <h4>Transaksi Gagal</h4>
            <p id="txErrorMessage" style="color: #555;">Terjadi kesalahan.</p>
            <button type="button" id="closeTxErrorModalBtn" class="btn btn-danger" style="max-width: 200px; margin: 20px auto 0;">OK</button>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const nomorInput = document.getElementById('nomorInput');
            const messageDisplay = document.getElementById('message-display');
            const productsContainer = document.getElementById('products-container');
            const freshProductsContainer = document.getElementById('fresh-products');
            const bekasanProductsContainer = document.getElementById('bekasan-products');
            const tabButtons = document.querySelectorAll('.tab-button');
            
            const detailModal = document.getElementById('productModal');
            const closeModalBtns = document.querySelectorAll('.modal-close-btn, .closeModalBtn');
            const buyView = document.getElementById('buyView');
            const detailView = document.getElementById('detailView');
            const buyForm = document.getElementById('buyForm');
            const buyButton = document.getElementById('buyButton');
            
            const txErrorModal = document.getElementById('txErrorModal');
            const txErrorMessage = document.getElementById('txErrorMessage');
            const closeTxErrorModalBtn = document.getElementById('closeTxErrorModalBtn');

            let debounceTimer;
            let productsFetched = false;
            let allProducts = [];
            let pollingInterval = null;

            const showMessage = (text, type = 'info') => {
                messageDisplay.textContent = text;
                messageDisplay.className = `tembak-info-box ${type}`;
                messageDisplay.style.display = text ? 'block' : 'none';
            };

            const formatCurrency = (amount) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);

            const updateBalance = () => {
                const userBalanceElement = document.getElementById('user-balance');
                if (userBalanceElement) {
                    fetch('/api/user').then(res => res.json()).then(data => {
                        if (data && data.balance != null) userBalanceElement.textContent = formatCurrency(data.balance);
                    });
                }
            };
            
            const cekNomorXl = (nomor) => {
                const cleaned = String(nomor).replace(/[\s+-]/g, '');
                if (!cleaned.startsWith('08')) return false;
                const prefixXl = ['817', '818', '819', '859', '877', '878', '838', '831', '832', '833'];
                return prefixXl.includes(cleaned.substring(1, 4));
            };

            const renderProductList = (products, targetContainer) => {
                targetContainer.innerHTML = '';
                if (!products || products.length === 0) {
                    targetContainer.innerHTML = `<p style="text-align: center; color: var(--text-muted-light);">Tidak ada produk di kategori ini.</p>`;
                    return;
                }
                targetContainer.innerHTML = products.map(product => `
                    <div class="product-item" data-code="${product.code || product.type}" style="cursor: pointer;">
                        <table>
                            <tr>
                                <td class="product-name">
                                    ${product.nama || product.name}
                                    <div style="font-size: 0.8rem; color: var(--text-muted-light); margin-top: 5px;">
                                        Sisa Slot: <strong style="color: ${product.sisa_slot > 0 ? '#10b981' : '#ef4444'};">${product.sisa_slot}</strong>
                                    </div>
                                </td>
                                <td class="product-fee-info">
                                    <span class="product-fee-label">Harga</span>
                                    <div class="product-fee-value">${formatCurrency(product.final_price || product.harga)}</div>
                                </td>
                            </tr>
                        </table>
                    </div>
                `).join('');
            };

            const displayProducts = (products) => {
                allProducts = products;
                const freshProducts = allProducts.filter(p => (p.code || p.type).toUpperCase().includes('XLA'));
                const bekasanProducts = allProducts.filter(p => (p.code || p.type).toUpperCase().includes('XDA'));
                renderProductList(freshProducts, freshProductsContainer);
                renderProductList(bekasanProducts, bekasanProductsContainer);
            };

            const fetchProducts = async () => {
                if (productsFetched) return;
                showMessage('Mengambil daftar produk...', 'info');
                productsContainer.style.display = 'block';
                try {
                    const response = await fetch('/api/v3/xl/stock-khfy', { method: 'POST' });
                    const result = await response.json();
                    if (!response.ok || !result.success) throw new Error(result.message);
                    productsFetched = true;
                    showMessage('', 'info');
                    displayProducts(result.data);
                } catch (error) {
                    showMessage(error.message, 'error');
                    productsContainer.style.display = 'none';
                }
            };

            nomorInput.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value.startsWith('62')) this.value = '0' + this.value.substring(2);
                clearTimeout(debounceTimer);
                const value = this.value;
                if (value.length >= 4) {
                    if (cekNomorXl(value)) {
                        showMessage('Nomor XL Valid. Memuat...', 'info');
                        debounceTimer = setTimeout(fetchProducts, 300);
                    } else { showMessage('Bukan nomor XL.', 'error'); productsContainer.style.display = 'none'; productsFetched = false; }
                } else { showMessage('', 'info'); productsContainer.style.display = 'none'; productsFetched = false; }
            });

            tabButtons.forEach(button => {
                button.addEventListener('click', () => {
                    tabButtons.forEach(btn => btn.classList.remove('active'));
                    document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
                    button.classList.add('active');
                    document.getElementById(button.getAttribute('data-tab') + '-products').classList.add('active');
                });
            });
            
            const startPolling = (ref_id) => {
                if (pollingInterval) clearInterval(pollingInterval);
                pollingInterval = setInterval(async () => {
                    try {
                        const res = await fetch(`/api/transaction/status/${ref_id}`);
                        if (!res.ok) { clearInterval(pollingInterval); return; }
                        const data = await res.json();
                        const statusInput = document.getElementById('detailStatus');
                        const messageInput = document.getElementById('detailMessage');
                        const loadingLine = document.querySelector('#detailView .loading-line');
                        if (messageInput && data.message) messageInput.value = data.message;
                        if (statusInput && statusInput.value.toLowerCase() !== data.status.toLowerCase()) {
                            statusInput.value = data.status.toUpperCase();
                            if (['success', 'sukses', 'failed', 'gagal'].includes(data.status.toLowerCase())) {
                                clearInterval(pollingInterval);
                                if (loadingLine) loadingLine.style.display = 'none';
                                if(['failed', 'gagal'].includes(data.status.toLowerCase())) updateBalance();
                            }
                        }
                    } catch (error) { clearInterval(pollingInterval); }
                }, 5000);
            };

            productsContainer.addEventListener('click', (e) => {
                const item = e.target.closest('.product-item');
                if (!item) return;
                const product = allProducts.find(p => (p.code || p.type) === item.dataset.code);
                if (product) {
                    buyForm.dataset.code = product.code || product.type;
                    document.getElementById('modalNomor').value = nomorInput.value;
                    document.getElementById('modalNamaProduk').value = product.nama || product.name;
                    document.getElementById('modalHarga').value = formatCurrency(product.final_price || product.harga);
                    document.getElementById('modalDescription').innerHTML = `<ul style="padding-left:20px;"><li>Area 1: ${product.area1||'-'}</li><li>Area 2: ${product.area2||'-'}</li><li>Area 3: ${product.area3||'-'}</li><li>Area 4: ${product.area4||'-'}</li></ul>`;
                    buyView.style.display = 'block'; detailView.style.display = 'none';
                    detailModal.style.display = 'block';
                }
            });

            buyForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const code = buyForm.dataset.code;
                const destination = document.getElementById('modalNomor').value;
                buyButton.disabled = true; buyButton.textContent = 'Memproses...';
                try {
                    const response = await fetch('/api/xl/akrabv3/order', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code, destination })
                    });
                    const result = await response.json();
                    if (!response.ok || !result.success) throw new Error(result.message);
                    
                    document.getElementById('detailRefId').value = result.data.ref_id || '-';
                    document.getElementById('detailNomor').value = result.data.destination;
                    document.getElementById('detailNamaProduk').value = document.getElementById('modalNamaProduk').value;
                    document.getElementById('detailHarga').value = document.getElementById('modalHarga').value;
                    document.getElementById('detailStatus').value = result.data.status.toUpperCase();
                    document.getElementById('detailMessage').value = result.data.message;
                    
                    buyView.style.display = 'none'; detailView.style.display = 'block';
                    updateBalance();
                    
                    if (result.data.ref_id && !['success', 'failed'].includes(result.data.status)) {
                        document.querySelector('#detailView .loading-line').style.display = 'block';
                        startPolling(result.data.ref_id);
                    } else document.querySelector('#detailView .loading-line').style.display = 'none';
                } catch (error) { detailModal.style.display = 'none'; showTxErrorModal(error.message); } 
                finally { buyButton.disabled = false; buyButton.textContent = 'Beli'; }
            });

            const hideModal = () => { if (pollingInterval) clearInterval(pollingInterval); detailModal.style.display = 'none'; txErrorModal.style.display = 'none'; };
            const showTxErrorModal = (msg) => { txErrorMessage.textContent = msg; txErrorModal.style.display = 'block'; };
            closeModalBtns.forEach(btn => btn.addEventListener('click', hideModal));
            closeTxErrorModalBtn.addEventListener('click', hideModal);
            window.addEventListener('click', (e) => { if ([detailModal, txErrorModal].includes(e.target)) hideModal(); });
        });
    </script>
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
