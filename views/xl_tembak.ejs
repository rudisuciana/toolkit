<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XL Tembak - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/qrcode-generator/qrcode.js"></script>
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        <div class="profile-card">
            <h2><i class="fas fa-bullseye"></i> XL Tembak Paket</h2>
            <p class="topup-subtitle">Pastikan nomor sudah login di menu <strong>XL Auth</strong> sebelum melanjutkan.</p>
            
            <div id="message-display" class="tembak-info-box" style="display: none; margin-bottom: 15px;"></div>
            
            <form id="tembakForm" onsubmit="return false;">
                <div class="form-group">
                    <label for="nomorInput">Nomor XL</label>
                    <input type="tel" id="nomorInput" name="number" placeholder="Contoh: 087812345678" class="form-input" autocomplete="off" required>
                </div>
                
                <button type="button" id="loginButton" class="btn btn-success" style="display: none; margin-top: 15px;">
                    <i class="fas fa-sign-in-alt"></i> Masuk & Ambil Paket
                </button>
            </form>
        </div>

        <div id="products-container" class="profile-card" style="display: none; margin-top: 20px;">
            <h3><i class="fas fa-shopping-cart"></i> Pilih Produk</h3>
            
            <div class="form-group" style="margin-top: 15px;">
                <label for="categoryFilter"><i class="fas fa-filter"></i> Kategori Paket</label>
                <select id="categoryFilter" class="form-input">
                    <option value="Semua Kategori">Semua Kategori</option>
                </select>
            </div>
            
            <div id="product-list" style="margin-top: 15px;"></div>
        </div>
    </main>

    <div id="buyModal" class="modal">
        <div class="modal-content">
            <span id="closeModalBtn_xl" class="modal-close-btn">&times;</span>
            <h3 id="modalTitle">KONFIRMASI PEMBELIAN</h3>
            <hr>
            <form id="buyForm" data-code="">
                <div class="form-group">
                    <label>Nama Produk</label>
                    <input id="modalProductName" class="form-input" type="text" readonly disabled>
                </div>
                <div class="form-group">
                    <label>Nomor Tujuan</label>
                    <input id="modalNumber" class="form-input" type="text" readonly disabled style="font-weight: bold;">
                </div>
                <div class="form-group">
                    <label>Harga Paket</label>
                    <input id="modalFee" class="form-input" type="text" readonly disabled style="color: #5c67f2; font-weight: bold;">
                </div>
                
                <div class="form-group">
                    <label for="modalPaymentMethod">Metode Pembayaran</label>
                    <select id="modalPaymentMethod" name="payment" class="form-input" style="background-color: #f0f8ff; border-color: #a7d9f2;">
                        </select>
                </div>

                <div id="modalPriceInfoContainer" class="info-box-blue" style="display: none; font-size: 0.9rem;">
                    <p id="modalPriceInfo" style="margin: 0;"></p>
                </div>

                <div class="modal-button-container">
                    <button type="button" id="closeModalButton" class="btn btn-danger">Batal</button>
                    <button type="submit" id="buyButton" class="btn btn-success">Beli Sekarang</button>
                </div>
            </form>
        </div>
    </div>

    <div id="txDetailModal" class="modal">
        <div class="modal-content">
            <div class="modal-title-container">
                <h3>DETAIL TRANSAKSI</h3>
                <div class="loading-line"></div>
            </div>
            <hr>
            <form id="txDetailForm">
                <div class="form-group"><label>Ref ID</label><input id="txRefId" class="form-input" type="text" readonly disabled></div>
                <div class="form-group"><label>Produk</label><input id="txProductName" class="form-input" type="text" readonly disabled></div>
                <div class="form-group"><label>Status</label><input id="txStatus" class="form-input" type="text" readonly disabled style="font-weight: bold;"></div>
                <div class="form-group"><label>Pesan</label><input id="txMessage" class="form-input" type="text" readonly disabled></div>
                
                <div class="form-group">
                    <label>Pembayaran</label>
                    <div class="payment-display" style="display: flex; gap: 10px; align-items: center;">
                        <input id="txPaymentMethod" class="form-input" type="text" readonly disabled style="flex-grow: 1;">
                        <span id="txPaymentAction"></span>
                    </div>
                </div>
                
                <button type="button" id="closeTxDetailModalBtn" class="btn btn-secondary" style="margin-top: 15px;">Tutup</button>
            </form>
        </div>
    </div>

    <div id="xlQrisModal" class="modal">
        <div class="modal-content">
             <span class="modal-close-btn" onclick="document.getElementById('xlQrisModal').style.display = 'none'">&times;</span>
            <h3>Scan QRIS</h3>
            <div id="xlQrisContainer" style="padding: 15px; background-color: white; margin: 20px auto; display: inline-block; border-radius: 8px;"></div>
        </div>
    </div>
    
    <div id="txErrorModal" class="modal">
        <div class="modal-content">
            <div class="modal-icon" style="color: #d9534f; font-size: 4rem; margin-bottom: 15px;"><i class="fas fa-times-circle"></i></div>
            <h4>Transaksi Gagal</h4>
            <p id="txErrorMessage" style="color: #555;">Terjadi kesalahan.</p>
            <button type="button" id="closeTxErrorModalBtn" class="btn btn-danger" style="max-width: 200px; margin: 20px auto 0;">OK</button>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- Inisialisasi Elemen ---
            const nomorInput = document.getElementById('nomorInput');
            const messageDisplay = document.getElementById('message-display');
            const loginButton = document.getElementById('loginButton');
            const productsContainer = document.getElementById('products-container');
            const categoryFilter = document.getElementById('categoryFilter');
            const productList = document.getElementById('product-list');
            
            // Modal Beli
            const buyModal = document.getElementById('buyModal');
            const closeModalButton = document.getElementById('closeModalButton');
            const modalCloseBtn = document.getElementById('closeModalBtn_xl');
            const buyForm = document.getElementById('buyForm');
            const buyButton = document.getElementById('buyButton');
            
            // Modal Detail Transaksi
            const txDetailModal = document.getElementById('txDetailModal');
            const closeTxDetailModalBtn = document.getElementById('closeTxDetailModalBtn');
            const txPaymentActionContainer = document.getElementById('txPaymentAction');

            // Modal QRIS
            const xlQrisModal = document.getElementById('xlQrisModal');
            const xlQrisContainer = document.getElementById('xlQrisContainer');
            
            // Modal Error
            const txErrorModal = document.getElementById('txErrorModal');
            const txErrorMessage = document.getElementById('txErrorMessage');
            const closeTxErrorModalBtn = document.getElementById('closeTxErrorModalBtn');
            
            let allProducts = [];
            let pollingInterval = null;

            // --- Helper Functions ---

            const formatCurrency = (amount) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);

            const showMessage = (text, type = 'info') => {
                messageDisplay.textContent = text;
                messageDisplay.className = `tembak-info-box ${type}`;
                messageDisplay.style.display = text ? 'block' : 'none';
            };

            const updateBalance = () => {
                const userBalanceElement = document.getElementById('user-balance');
                if (userBalanceElement) {
                    fetch('/api/user')
                        .then(res => res.json())
                        .then(data => {
                            if (data && data.balance != null) userBalanceElement.textContent = formatCurrency(data.balance);
                        });
                }
            };

            // --- Event Input Nomor ---
            nomorInput.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, ''); // Hanya angka
                if (this.value.startsWith('62')) this.value = '0' + this.value.substring(2);
                
                // Validasi Prefix XL
                const isValidXl = ['0817','0818','0819','0859','0877','0878','0838','0831','0832','0833'].some(p => this.value.startsWith(p));
                
                if (isValidXl && this.value.length >= 10) {
                    loginButton.style.display = 'block';
                    showMessage('');
                } else {
                    loginButton.style.display = 'none';
                    if (this.value.length >= 4 && !isValidXl) {
                        showMessage('Bukan nomor XL/Axis.', 'error');
                    } else {
                        showMessage('');
                    }
                }
            });

            // --- Login & Ambil Produk ---
            loginButton.addEventListener('click', async () => {
                const number = nomorInput.value;
                showMessage('Memverifikasi sesi...', 'info');
                loginButton.disabled = true;
                loginButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';

                try {
                    // 1. Cek Sesi
                    const sessionRes = await fetch('/api/xl/check-session', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ number })
                    });
                    const sessionData = await sessionRes.json();
                    if (!sessionRes.ok || !sessionData.success) throw new Error(sessionData.message || 'Nomor belum login. Silakan ke menu XL Auth.');

                    // 2. Ambil Produk
                    showMessage('Mengambil daftar paket...', 'info');
                    const productsRes = await fetch('/api/xl/get-products', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ number: '62' + number.substring(1) })
                    });
                    const productsData = await productsRes.json();
                    if (!productsRes.ok || !productsData.success) throw new Error(productsData.message);

                    // 3. Tampilkan
                    showMessage('', 'info');
                    nomorInput.readOnly = true;
                    loginButton.style.display = 'none';
                    displayProducts(productsData.data.products);

                } catch (error) {
                    showMessage(error.message, 'error');
                } finally {
                    loginButton.disabled = false;
                    loginButton.innerHTML = '<i class="fas fa-sign-in-alt"></i> Masuk & Ambil Paket';
                }
            });

            // --- Tampilkan Produk ---
            function displayProducts(products) {
                allProducts = products || [];
                productsContainer.style.display = 'block';
                
                // Generate Kategori
                const categories = ['Semua Kategori', ...new Set(allProducts.map(p => p.category))];
                categoryFilter.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join('');
                
                renderProductList('Semua Kategori');
            }

            function renderProductList(category) {
                productList.innerHTML = '';
                const filtered = (category === 'Semua Kategori') ? allProducts : allProducts.filter(p => p.category === category);
                
                if(filtered.length === 0) {
                    productList.innerHTML = '<p style="text-align:center; color:#888;">Tidak ada produk di kategori ini.</p>';
                    return;
                }

                filtered.forEach(p => {
                    const item = document.createElement('div');
                    item.className = 'product-item';
                    item.dataset.code = p.code;
                    item.innerHTML = `
                        <table>
                            <tr>
                                <td class="product-name">
                                    ${p.name}
                                    <div style="font-size:0.8rem; color:#888; margin-top:3px;">${p.category || ''}</div>
                                </td>
                                <td class="product-fee-info">
                                    <span class="product-fee-label">Harga</span>
                                    <div class="product-fee-value">${formatCurrency(p.final_price)}</div>
                                </td>
                            </tr>
                        </table>
                    `;
                    // Event click untuk membuka modal
                    item.addEventListener('click', () => openBuyModal(p));
                    productList.appendChild(item);
                });
            }

            // Filter Change
            categoryFilter.addEventListener('change', () => renderProductList(categoryFilter.value));

            // --- Modal Pembelian ---
            function openBuyModal(product) {
                document.getElementById('modalProductName').value = product.name;
                document.getElementById('modalNumber').value = nomorInput.value;
                document.getElementById('modalFee').value = formatCurrency(product.final_price);
                
                // Isi Dropdown Pembayaran
                const paymentSelect = document.getElementById('modalPaymentMethod');
                paymentSelect.innerHTML = product.payment_methods.map(m => `<option value="${m}">${m}</option>`).join('');
                
                // Info Harga Pulsa (Jika ada)
                const priceInfoContainer = document.getElementById('modalPriceInfoContainer');
                const priceInfo = document.getElementById('modalPriceInfo');
                
                if (product.price) {
                    const amountToShow = product.price.pulsa > 0 ? product.price.pulsa : product.price.non_pulsa;
                    if (amountToShow > 0) {
                        priceInfo.innerHTML = `<i class="fas fa-info-circle"></i> Paket ini memotong pulsa/e-wallet sebesar <strong>${formatCurrency(amountToShow)}</strong>.`;
                        priceInfoContainer.style.display = 'block';
                    } else {
                        priceInfoContainer.style.display = 'none';
                    }
                } else {
                    priceInfoContainer.style.display = 'none';
                }
                
                buyForm.dataset.code = product.code;
                buyModal.style.display = 'block';
            }

            // --- Render Tombol Bayar di Detail ---
            const renderPaymentActionButton = (txData) => {
                txPaymentActionContainer.innerHTML = '';
                const paymentMethod = (txData.payment_method || '').toUpperCase();
                const paymentInfo = txData.payment_info;
                const eWallet = ['DANA', 'GOPAY', 'SHOPEEPAY', 'OVO'];

                if (eWallet.includes(paymentMethod) && paymentInfo) {
                    // Tombol Link
                    const link = document.createElement('a');
                    link.href = paymentInfo;
                    link.target = '_blank';
                    link.className = 'btn-small btn-view';
                    link.innerHTML = '<i class="fas fa-external-link-alt"></i> Bayar';
                    txPaymentActionContainer.appendChild(link);
                } else if (paymentMethod === 'QRIS' && paymentInfo) {
                    // Tombol QRIS
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'btn-small btn-view';
                    button.innerHTML = '<i class="fas fa-qrcode"></i> QR Code';
                    button.onclick = () => showXlQrisModal(paymentInfo);
                    txPaymentActionContainer.appendChild(button);
                }
            };
            
            // --- Tampilkan QRIS ---
            function showXlQrisModal(qrisString) {
                xlQrisContainer.innerHTML = '';
                if (qrisString.startsWith('data:image')) {
                    const img = document.createElement('img');
                    img.src = qrisString;
                    img.style.maxWidth = '250px';
                    xlQrisContainer.appendChild(img);
                } else {
                    const qr = qrcode(0, 'M');
                    qr.addData(qrisString);
                    qr.make();
                    xlQrisContainer.innerHTML = qr.createImgTag(6, 8);
                }
                xlQrisModal.style.display = 'block';
            }

            // --- Polling Status ---
            const startPolling = (ref_id) => {
                if (pollingInterval) clearInterval(pollingInterval);
                
                pollingInterval = setInterval(async () => {
                    try {
                        const res = await fetch(`/api/transaction/status/${ref_id}`);
                        if (!res.ok) { clearInterval(pollingInterval); return; }
                        const data = await res.json();
                        
                        const statusInput = document.getElementById('txStatus');
                        const messageInput = document.getElementById('txMessage');
                        const loadingLine = document.querySelector('#txDetailModal .loading-line');

                        if (messageInput && data.message) messageInput.value = data.message;

                        if (statusInput && statusInput.value.toLowerCase() !== data.status.toLowerCase()) {
                            statusInput.value = data.status.toUpperCase();
                            
                            // Jika Transaksi Selesai (Sukses/Gagal)
                            if (['success', 'sukses', 'failed', 'gagal'].includes(data.status.toLowerCase())) {
                                clearInterval(pollingInterval);
                                if (loadingLine) loadingLine.style.display = 'none';
                                
                                // Render Tombol Bayar jika Sukses (menunggu pembayaran user ke provider)
                                if (['success', 'sukses'].includes(data.status.toLowerCase())) {
                                    renderPaymentActionButton({
                                        payment_method: document.getElementById('txPaymentMethod').value,
                                        payment_info: data.payment_info
                                    });
                                }
                                
                                // Update Saldo jika Gagal (Refund)
                                if(['failed', 'gagal'].includes(data.status.toLowerCase())) {
                                    updateBalance();
                                }
                            }
                        }
                    } catch (error) {
                        console.error('Polling error:', error);
                        clearInterval(pollingInterval);
                    }
                }, 5000);
            };

            function showTxDetailModal(data, productName, paymentMethod) {
                if (!data) return;
                document.getElementById('txMessage').value = data.message || 'Memproses...';
                document.getElementById('txStatus').value = (data.status || 'PENDING').toUpperCase();
                document.getElementById('txRefId').value = data.ref_id || '-';
                document.getElementById('txProductName').value = productName || '-';
                // document.getElementById('txDestination').value = data.destination || '-'; // Tidak ada input destination di HTML form detail, bisa ditambah jika perlu
                document.getElementById('txPaymentMethod').value = paymentMethod || '-';

                const loadingLine = document.querySelector('#txDetailModal .loading-line');
                if (loadingLine) loadingLine.style.display = 'block';
                txPaymentActionContainer.innerHTML = '';

                // Cek status awal
                const initialStatus = data.status ? data.status.toLowerCase() : '';
                if (['success', 'sukses'].includes(initialStatus)) {
                    if (loadingLine) loadingLine.style.display = 'none';
                    renderPaymentActionButton({
                        payment_method: paymentMethod,
                        payment_info: data.payment_info
                    });
                }

                txDetailModal.style.display = 'block';
                
                // Jalankan polling jika belum final
                if (!['success', 'sukses', 'failed', 'gagal'].includes(initialStatus)) {
                    startPolling(data.ref_id);
                }
            }

            // --- Submit Transaksi ---
            buyForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const code = buyForm.dataset.code;
                const number = document.getElementById('modalNumber').value;
                const payment = document.getElementById('modalPaymentMethod').value;
                
                buyButton.disabled = true;
                buyButton.textContent = 'Memproses...';
                
                try {
                    const res = await fetch('/api/xl/buy-package', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ number, code, payment })
                    });
                    const result = await res.json();
                    
                    hideAllModals();

                    if (result.success) {
                        const product = allProducts.find(p => p.code === code);
                        const productName = product ? product.name : 'Produk';
                        showTxDetailModal(result.data, productName, payment);
                        updateBalance();
                    } else {
                        showTxErrorModal(result.message);
                    }

                } catch (error) {
                    hideAllModals();
                    showTxErrorModal(error.message);
                } finally {
                    buyButton.disabled = false;
                    buyButton.textContent = 'Beli Sekarang';
                }
            });
            
            // --- Modal Management ---
            const hideAllModals = () => {
                if (pollingInterval) clearInterval(pollingInterval);
                buyModal.style.display = 'none';
                txDetailModal.style.display = 'none';
                txErrorModal.style.display = 'none';
                xlQrisModal.style.display = 'none';
            };

            const showTxErrorModal = (message) => {
                txErrorMessage.textContent = message || 'Terjadi kesalahan.';
                txErrorModal.style.display = 'block';
            };

            // Event Listeners Tombol Tutup
            [closeModalButton, modalCloseBtn, closeTxDetailModalBtn, closeTxErrorModalBtn].forEach(btn => {
                if(btn) btn.addEventListener('click', hideAllModals);
            });
            
            window.addEventListener('click', (e) => { 
                if ([buyModal, txDetailModal, txErrorModal, xlQrisModal].includes(e.target)) {
                    hideAllModals(); 
                }
            });
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
