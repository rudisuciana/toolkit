<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content admin-container">
        
        <div class="admin-top-buttons">
            <button id="serverBtn" class="btn btn-info" disabled>
                <i class="fas fa-server"></i> SERVER (Maintenance)
            </button>
            <button id="noOtpBtn" class="btn" style="background: linear-gradient(135deg, #8b5cf6, #6366f1);">
                <i class="fas fa-plus-circle"></i> Produk No OTP
            </button>
        </div>

        <div class="announcement-card">
            <h2><i class="fas fa-bullhorn"></i> Pengumuman Saat Ini</h2>
            <div id="current-announcement" style="font-size: 0.95rem; line-height: 1.6; white-space: pre-wrap;">Memuat...</div>
            
            <button id="editAnnouncementBtn" class="edit-announcement-btn">
                <i class="fas fa-pen"></i>
            </button>
        </div>

        <div class="admin-sidebar">
            <h4><i class="fas fa-database"></i> Database Tables</h4>
            <ul id="table-list">
                <div class="spinner" style="margin: 10px auto;"></div>
            </ul>
        </div>

        <div class="admin-content">
            <div class="profile-card" id="data-display-card" style="display: none;">
                <h3 id="current-table-title" style="border-bottom: none; margin-bottom: 15px;">Data Tabel</h3>
                
                <div class="filter-container" style="padding: 0; margin-bottom: 15px;">
                    <div class="form-group" style="flex-grow: 1;">
                        <input type="text" id="searchInput" class="form-input" placeholder="Cari data...">
                    </div>
                    <button id="searchBtn" class="btn btn-small btn-view"><i class="fas fa-search"></i> Cari</button>
                </div>

                <div class="table-responsive-wrapper">
                    <table class="deposit-table">
                        <thead id="data-table-head"></thead>
                        <tbody id="data-table-body"></tbody>
                    </table>
                </div>
            </div>
            
            <div id="loading-spinner" style="display: none; text-align: center; padding: 20px;">
                <div class="spinner" style="margin: 0 auto;"></div>
                <p style="margin-top: 10px; color: var(--text-muted-light);">Memuat data...</p>
            </div>
        </div>
    </main>

    <div id="editModal" class="modal">
        <div class="modal-content">
            <span class="modal-close-btn">&times;</span>
            <h3>Edit Data</h3>
            <form id="editForm">
                <div id="edit-form-fields" style="max-height: 400px; overflow-y: auto;"></div>
                <div class="modal-button-container">
                    <button type="button" class="btn btn-danger closeModalBtn">Batal</button>
                    <button type="submit" class="btn btn-success">Simpan</button>
                </div>
            </form>
        </div>
    </div>

    <div id="noOtpModal" class="modal">
        <div class="modal-content">
            <span class="modal-close-btn">&times;</span>
            <h3>Tambah Produk</h3>
            <form id="noOtpForm">
                <div class="form-group"><label>ID Produk</label><input type="text" name="product_id" class="form-input" required></div>
                <div class="form-group"><label>Nama Produk</label><input type="text" name="product_name" class="form-input" required></div>
                <div class="form-group"><label>Harga</label><input type="number" name="amount" class="form-input" required></div>
                <div class="form-group"><label>Kategori</label><input type="text" name="category" class="form-input"></div>
                <div class="form-group"><label>Provider</label><input type="text" name="provider" class="form-input"></div>
                <div class="form-group"><label>Deskripsi</label><textarea name="description" class="form-input" rows="2"></textarea></div>
                
                <div class="modal-button-container">
                    <button type="button" class="btn btn-danger closeModalBtn">Tutup</button>
                    <button type="submit" class="btn btn-success">Simpan</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editAnnouncementModal" class="modal">
        <div class="modal-content">
            <span class="modal-close-btn">&times;</span>
            <h3>Edit Pengumuman</h3>
            <form id="announcementForm">
                <div class="form-group">
                    <label>Isi Pengumuman</label>
                    <textarea id="announcementInput" name="announcement" class="form-input" rows="6"></textarea>
                </div>
                <div class="modal-button-container">
                    <button type="button" class="btn btn-danger closeModalBtn">Batal</button>
                    <button type="submit" class="btn btn-success">Update</button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // DOM Elements
            const tableList = document.getElementById('table-list');
            const dataDisplayCard = document.getElementById('data-display-card');
            const tableTitle = document.getElementById('current-table-title');
            const dataTableHead = document.getElementById('data-table-head');
            const dataTableBody = document.getElementById('data-table-body');
            const searchInput = document.getElementById('searchInput');
            const searchBtn = document.getElementById('searchBtn');
            const loadingSpinner = document.getElementById('loading-spinner');
            
            // Modals
            const editModal = document.getElementById('editModal');
            const noOtpModal = document.getElementById('noOtpModal');
            const announcementModal = document.getElementById('editAnnouncementModal');
            const closeModalBtns = document.querySelectorAll('.closeModalBtn, .modal-close-btn');

            // Forms
            const editForm = document.getElementById('editForm');
            const editFormFields = document.getElementById('edit-form-fields');
            const noOtpForm = document.getElementById('noOtpForm');
            const announcementForm = document.getElementById('announcementForm');

            // Announcement
            const currentAnnouncementEl = document.getElementById('current-announcement');
            const editAnnouncementBtn = document.getElementById('editAnnouncementBtn');
            const announcementInput = document.getElementById('announcementInput');

            let currentTable = '';
            let primaryKeyColumn = '';

            // Helper: Format Currency
            const formatCurrency = (val) => new Intl.NumberFormat('id-ID').format(val);

            // 1. Fetch Announcement
            fetch('/api/announcement')
                .then(res => res.json())
                .then(data => {
                    if (data.success) currentAnnouncementEl.textContent = data.announcement || '-';
                });

            editAnnouncementBtn.addEventListener('click', () => {
                announcementInput.value = currentAnnouncementEl.textContent;
                announcementModal.style.display = 'block';
            });

            announcementForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                try {
                    const res = await fetch('/api/admin/update-announcement', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ announcement: announcementInput.value })
                    });
                    const data = await res.json();
                    if(data.success) {
                        currentAnnouncementEl.textContent = announcementInput.value;
                        announcementModal.style.display = 'none';
                        alert('Berhasil update!');
                    }
                } catch(err) { alert('Gagal update'); }
            });

            // 2. Fetch Tables
            fetch('/api/admin/tables')
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        tableList.innerHTML = result.tables.map(table => `
                            <li>
                                <button data-table="${table}">
                                    <i class="fas fa-table" style="color: var(--primary-color);"></i> ${table}
                                </button>
                            </li>
                        `).join('');
                        
                        // Add Click Events
                        document.querySelectorAll('#table-list button').forEach(btn => {
                            btn.addEventListener('click', () => {
                                document.querySelectorAll('#table-list button').forEach(b => b.classList.remove('active'));
                                btn.classList.add('active');
                                fetchTableData(btn.dataset.table);
                            });
                        });
                    }
                });

            // 3. Fetch Table Data
            const fetchTableData = async (tableName, searchTerm = '') => {
                loadingSpinner.style.display = 'block';
                dataDisplayCard.style.display = 'none';
                currentTable = tableName;
                tableTitle.innerHTML = `<i class="fas fa-database"></i> Tabel: ${tableName}`;

                try {
                    const res = await fetch(`/api/admin/table-data/${tableName}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ searchTerm })
                    });
                    const result = await res.json();
                    
                    if (!result.success) throw new Error(result.message);

                    primaryKeyColumn = result.primaryKey;
                    
                    // Header
                    dataTableHead.innerHTML = `<tr>
                        <th style="width: 100px;">Aksi</th>
                        ${result.columns.map(col => `<th>${col}</th>`).join('')}
                    </tr>`;

                    // Body
                    dataTableBody.innerHTML = '';
                    if (result.data.length === 0) {
                        dataTableBody.innerHTML = `<tr><td colspan="${result.columns.length + 1}" style="text-align:center; padding:20px;">Tidak ada data.</td></tr>`;
                    } else {
                        result.data.forEach(row => {
                            const tr = document.createElement('tr');
                            const pkValue = row[primaryKeyColumn];
                            
                            const actions = `<td>
                                <div style="display:flex; gap:5px; justify-content:center;">
                                    <button class="btn-small btn-view edit-btn" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn-small btn-danger-small delete-btn" title="Hapus"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>`;

                            const cells = result.columns.map(col => {
                                let val = row[col];
                                if (val === null) val = '<span style="color:#aaa;">NULL</span>';
                                else if (typeof val === 'string' && val.length > 30) val = val.substring(0, 30) + '...';
                                return `<td>${val}</td>`;
                            }).join('');

                            tr.innerHTML = actions + cells;
                            tr.dataset.rowData = JSON.stringify(row);
                            tr.querySelector('.edit-btn').dataset.pk = pkValue;
                            tr.querySelector('.delete-btn').dataset.pk = pkValue;
                            dataTableBody.appendChild(tr);
                        });
                    }
                    
                    dataDisplayCard.style.display = 'block';

                } catch (error) {
                    alert(error.message);
                } finally {
                    loadingSpinner.style.display = 'none';
                }
            };

            searchBtn.addEventListener('click', () => {
                if (currentTable) fetchTableData(currentTable, searchInput.value);
            });

            // Event Delegation for Edit/Delete
            dataTableBody.addEventListener('click', (e) => {
                const editBtn = e.target.closest('.edit-btn');
                const deleteBtn = e.target.closest('.delete-btn');

                if (editBtn) {
                    const rowData = JSON.parse(editBtn.closest('tr').dataset.rowData);
                    editFormFields.innerHTML = '';
                    
                    for (const key in rowData) {
                        const isPK = key === primaryKeyColumn;
                        let input = '';
                        const val = rowData[key] !== null ? rowData[key] : '';
                        
                        if (typeof val === 'string' && val.length > 50) {
                            input = `<textarea name="${key}" class="form-input" rows="3">${val}</textarea>`;
                        } else {
                            input = `<input type="text" name="${key}" class="form-input" value="${val}" ${isPK ? 'readonly style="background:#eee;color:#555;"' : ''}>`;
                        }

                        editFormFields.innerHTML += `
                            <div class="form-group">
                                <label style="font-size:0.8rem;">${key}</label>
                                ${input}
                            </div>`;
                    }
                    editModal.style.display = 'block';
                }

                if (deleteBtn) {
                    if(confirm('Hapus data ini permanen?')) {
                        const pkValue = deleteBtn.dataset.pk;
                        fetch('/api/admin/delete-row', {
                            method: 'POST',
                            headers: {'Content-Type':'application/json'},
                            body: JSON.stringify({ tableName: currentTable, primaryKeyColumn, primaryKeyValue: pkValue })
                        }).then(res => res.json()).then(data => {
                            if(data.success) fetchTableData(currentTable, searchInput.value);
                            else alert(data.message);
                        });
                    }
                }
            });

            // Save Edit
            editForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const formData = new FormData(editForm);
                const updatedData = {};
                const pkVal = formData.get(primaryKeyColumn);

                for(let [key, val] of formData.entries()) {
                    if (key !== primaryKeyColumn) updatedData[key] = val === '' ? null : val;
                }

                fetch('/api/admin/update-row', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({ tableName: currentTable, primaryKeyColumn, primaryKeyValue: pkVal, updatedData })
                }).then(res => res.json()).then(data => {
                    if(data.success) {
                        editModal.style.display = 'none';
                        fetchTableData(currentTable, searchInput.value);
                    } else alert(data.message);
                });
            });
            
            // No OTP
            document.getElementById('noOtpBtn').addEventListener('click', () => noOtpModal.style.display = 'block');
            noOtpForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const data = Object.fromEntries(new FormData(noOtpForm));
                fetch('/api/admin/no-otp/add', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify(data)
                }).then(res => res.json()).then(d => {
                    alert(d.message);
                    if(d.success) {
                        noOtpModal.style.display = 'none';
                        noOtpForm.reset();
                        if(currentTable === 'no_otp') fetchTableData('no_otp');
                    }
                });
            });

            // Close Modals
            const hideModals = () => {
                editModal.style.display = 'none';
                noOtpModal.style.display = 'none';
                announcementModal.style.display = 'none';
            };
            closeModalBtns.forEach(btn => btn.addEventListener('click', hideModals));
            window.addEventListener('click', (e) => {
                if([editModal, noOtpModal, announcementModal].includes(e.target)) hideModals();
            });
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
