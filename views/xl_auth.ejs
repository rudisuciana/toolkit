<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XL Authentication - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        <div class="profile-card">
            <h2><i class="fas fa-key"></i> Autentikasi XL</h2>
            <p id="subtitle" class="topup-subtitle">Kelola login nomor XL Anda (Minta OTP, Login, Cek Sesi).</p>
            
            <div id="message-display" class="tembak-info-box" style="display: none; margin-bottom: 15px;"></div>
            
            <div id="form-container">
                <form id="xlAuthForm" onsubmit="return false;">
                    <div class="form-group">
                        <label for="nomorInput">Nomor XL</label>
                        <input type="tel" id="nomorInput" name="number" placeholder="Contoh: 0878..." class="form-input" required>
                    </div>
                    
                    <div id="otp-group" class="form-group" style="display: none;">
                        <label for="otpInput">Kode OTP</label>
                        <input type="text" id="otpInput" name="otp" placeholder="Masukkan 6 digit kode OTP" class="form-input" maxlength="6" pattern="\d{6}" style="text-align: center; letter-spacing: 5px; font-size: 1.1rem;">
                        <small style="color: #888;">Cek SMS di HP Anda.</small>
                    </div>
                </form>
            </div>

            <div id="button-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px;">
                <button type="button" id="mainButton" class="btn btn-success">Minta OTP</button>
                <button type="button" id="secondaryButton" class="btn btn-secondary" style="background-color: #6c757d;">Cek Sesi</button>
            </div>
        </div>
        
        <div id="quota-results-container" class="profile-card" style="display: none; margin-top: 20px;">
            <h3><i class="fas fa-box-open"></i> Detail Paket & Kuota</h3>
            <div id="quota-list" style="margin-top: 15px;">
                <div class="spinner" style="margin: 20px auto;"></div>
            </div>
        </div>
    </main>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Inisialisasi Elemen
            const nomorInput = document.getElementById('nomorInput');
            const otpGroup = document.getElementById('otp-group');
            const otpInput = document.getElementById('otpInput');
            const mainButton = document.getElementById('mainButton');
            const secondaryButton = document.getElementById('secondaryButton');
            const messageDisplay = document.getElementById('message-display');
            const formContainer = document.getElementById('form-container');
            const quotaResultsContainer = document.getElementById('quota-results-container');
            const quotaList = document.getElementById('quota-list');
            
            let activeNumber = null;

            // --- Helper Functions ---
            
            // Format Input Nomor Otomatis
            nomorInput.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, ''); // Hanya angka
                if (this.value.startsWith('62')) {
                    this.value = '0' + this.value.substring(2); // Ubah 62 ke 0
                }
            });

            const showMessage = (text, type = 'info') => {
                messageDisplay.textContent = text;
                messageDisplay.className = `tembak-info-box ${type}`; // info, success, error
                messageDisplay.style.display = text ? 'block' : 'none';
            };

            const handleApiResponse = async (response) => {
                const data = await response.json();
                if (!response.ok) throw new Error(data.message || 'Terjadi kesalahan pada server.');
                return data;
            };

            // --- State Management ---

            const resetToInitialState = () => {
                showMessage('');
                formContainer.style.display = 'block';
                quotaResultsContainer.style.display = 'none';
                quotaList.innerHTML = '';
                otpGroup.style.display = 'none';
                otpInput.value = '';
                nomorInput.value = '';
                nomorInput.readOnly = false;
                activeNumber = null;
                
                mainButton.textContent = 'Minta OTP';
                mainButton.className = 'btn btn-success';
                
                secondaryButton.textContent = 'Cek Sesi';
                secondaryButton.style.backgroundColor = '#6c757d';
                
                mainButton.onclick = handleRequestOtp;
                secondaryButton.onclick = handleCheckSession;
                
                mainButton.disabled = false;
                secondaryButton.disabled = false;
            };

            const showLoggedInState = (number) => {
                activeNumber = number;
                formContainer.style.display = 'none'; // Sembunyikan form input agar bersih
                showMessage(`Sesi Aktif: ${number}`, 'success');
                
                mainButton.textContent = 'Cek Kuota';
                mainButton.className = 'btn btn-info';
                
                secondaryButton.textContent = 'Keluar / Reset';
                secondaryButton.style.backgroundColor = '#d9534f';
                
                mainButton.onclick = handleCheckQuota;
                secondaryButton.onclick = resetToInitialState;
            };
            
            // --- API Handlers ---

            const handleRequestOtp = async () => {
                const number = nomorInput.value;
                if (!number || number.length < 10) { showMessage('Masukkan nomor XL yang valid.', 'error'); return; }
                
                showMessage('Mengirim permintaan OTP...', 'info');
                mainButton.disabled = true;
                secondaryButton.disabled = true;
                
                try {
                    const response = await fetch('/api/xl/request-otp', { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify({ number }) 
                    });
                    const result = await handleApiResponse(response);
                    
                    if (result.success) {
                        showMessage('OTP Terkirim! Silakan cek SMS.', 'success');
                        otpGroup.style.display = 'block';
                        nomorInput.readOnly = true;
                        otpInput.focus();
                        
                        mainButton.textContent = 'Login';
                        secondaryButton.textContent = 'Batal';
                        
                        mainButton.onclick = handleLoginOtp;
                        secondaryButton.onclick = resetToInitialState;
                    } else {
                        showMessage(result.message || 'Gagal mengirim OTP.', 'error');
                    }
                } catch (error) {
                    showMessage(error.message, 'error');
                } finally {
                    mainButton.disabled = false;
                    secondaryButton.disabled = false;
                }
            };
            
            const handleLoginOtp = async () => {
                const number = nomorInput.value;
                const otp = otpInput.value;
                
                if (!otp || otp.length < 6) { showMessage('Kode OTP harus 6 digit.', 'error'); return; }
                
                showMessage('Memverifikasi OTP...', 'info');
                mainButton.disabled = true;
                secondaryButton.disabled = true;
                
                try {
                    const response = await fetch('/api/xl/login-otp', { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify({ number, otp }) 
                    });
                    const result = await handleApiResponse(response);
                    
                    if (result.success) {
                        showLoggedInState(number);
                    } else {
                        showMessage(result.message || 'Login gagal, OTP salah.', 'error');
                    }
                } catch (error) {
                    showMessage(error.message, 'error');
                } finally {
                    mainButton.disabled = false;
                    secondaryButton.disabled = false;
                }
            };

            const handleCheckSession = async () => {
                const number = nomorInput.value;
                if (!number) { showMessage('Masukkan nomor terlebih dahulu.', 'error'); return; }
                
                showMessage('Mengecek status sesi...', 'info');
                secondaryButton.disabled = true;
                mainButton.disabled = true;
                
                try {
                    const response = await fetch('/api/xl/check-session', { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify({ number }) 
                    });
                    const result = await handleApiResponse(response);
                    
                    if (result.success) {
                        showLoggedInState(number);
                    } else {
                        showMessage('Sesi tidak aktif atau kedaluwarsa. Silakan minta OTP.', 'error');
                    }
                } catch (error) {
                    showMessage(error.message, 'error');
                } finally {
                    secondaryButton.disabled = false;
                    mainButton.disabled = false;
                }
            };
            
            const handleCheckQuota = async () => {
                if (!activeNumber) return;
                
                showMessage('Mengambil data kuota...', 'info');
                mainButton.disabled = true;
                quotaResultsContainer.style.display = 'block';
                quotaList.innerHTML = '<div class="spinner" style="margin: 20px auto;"></div>';
                
                try {
                    const response = await fetch('/api/xl/check-quotas', { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify({ number: activeNumber }) 
                    });
                    const result = await handleApiResponse(response);
                    
                    if (result.success && result.data.length > 0) {
                        displayQuotas(result.data);
                        showMessage('Data kuota berhasil diperbarui.', 'success');
                    } else {
                        quotaList.innerHTML = `<p style="text-align:center; padding:15px;">${result.message || 'Tidak ada paket aktif yang ditemukan.'}</p>`;
                        showMessage('', 'info');
                    }
                } catch (error) {
                    quotaList.innerHTML = `<p style="color: #d9534f; text-align:center;">Error: ${error.message}</p>`;
                    showMessage(error.message, 'error');
                } finally {
                    mainButton.disabled = false;
                }
            };

            function displayQuotas(data) {
                quotaList.innerHTML = data.map(paket => `
                    <div class="quota-item active" style="margin-bottom: 10px;">
                        <div class="quota-header" style="background: #f9f9f9; padding: 10px; border-radius: 5px 5px 0 0; border: 1px solid #eee;">
                            <strong>${paket.name}</strong>
                            <span style="float: right; font-size: 0.85rem; color: #666;">Exp: ${paket.date_end}</span>
                        </div>
                        <div class="quota-details" style="padding: 10px; border: 1px solid #eee; border-top: none; border-radius: 0 0 5px 5px;">
                            <ul style="padding-left: 20px; margin: 0;">
                                ${paket.detail_quota.map(q => `
                                    <li style="margin-bottom: 5px;">
                                        ${q.name}: <strong style="color: #5cb85c;">${q.remaining_text}</strong> 
                                        <span style="color: #999; font-size: 0.8rem;">/ ${q.total_text}</span>
                                    </li>
                                `).join('')}
                            </ul>
                        </div>
                    </div>
                `).join('');
            }
            
            // Inisialisasi Listener Tombol
            mainButton.onclick = handleRequestOtp;
            secondaryButton.onclick = handleCheckSession;
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
