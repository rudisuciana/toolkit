<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Riwayat - WUZZSTORE</title>
    
    <link rel="stylesheet" href="/css/style-variables.css">
    <link rel="stylesheet" href="/css/style-layout.css">
    <link rel="stylesheet" href="/css/style-components.css">
    <link rel="stylesheet" href="/css/style-pages.css">
    <link rel="stylesheet" href="/css/style-dark.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/qrcode-generator/qrcode.js"></script>
</head>
<body class="dashboard">

    <%- include('partials/sidebar', { user: user }) %>
    <%- include('partials/header', { user: user }) %>

    <main class="main-content">
        
        <div class="history-item" id="topup-history-item">
            <div class="history-header">
                <span><i class="fas fa-wallet"></i> Riwayat Top Up</span>
                <i class="fas fa-chevron-right icon"></i>
            </div>
            <div class="history-details">
                <div class="filter-container">
                    <div class="form-group">
                        <input type="text" id="topupSearchInput" class="form-input" placeholder="Cari ID atau Nominal...">
                    </div>
                    <button id="topupSearchBtn" class="btn btn-small btn-view"><i class="fas fa-search"></i></button>
                    <button id="topupDateFilterBtn" class="btn btn-small btn-info"><i class="fas fa-calendar-alt"></i></button>
                </div>
                <div class="table-responsive-wrapper">
                    <table class="deposit-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Jumlah</th>
                                <th>Status</th>
                                <th>Waktu</th>
                            </tr>
                        </thead>
                        <tbody id="topup-history-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="history-item" id="transaction-history-item">
            <div class="history-header">
                <span><i class="fas fa-shopping-cart"></i> Riwayat Transaksi</span>
                <i class="fas fa-chevron-right icon"></i>
            </div>
            <div class="history-details">
                 <div class="filter-container">
                    <div class="form-group">
                        <input type="text" id="txSearchInput" class="form-input" placeholder="Cari Produk/Tujuan...">
                    </div>
                    <button id="txSearchBtn" class="btn btn-small btn-view"><i class="fas fa-search"></i></button>
                    <button id="txDateFilterBtn" class="btn btn-small btn-info"><i class="fas fa-calendar-alt"></i></button>
                </div>
                <div class="table-responsive-wrapper">
                    <table class="deposit-table">
                        <thead>
                            <tr>
                                <th>Ref ID</th>
                                <th>Produk</th>
                                <th>Tujuan</th>
                                <th>Harga</th>
                                <th>Status</th>
                                <th>Ket</th>
                            </tr>
                        </thead>
                        <tbody id="transaction-history-body"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="historyQrisModal" class="modal">
        <div class="modal-content">
             <span class="modal-close-btn" onclick="document.getElementById('historyQrisModal').style.display = 'none'">&times;</span>
            <h3>Scan Pembayaran</h3>
            <div style="display:flex; justify-content:center;">
                <div id="historyQrisContainer" style="padding:15px; background:#fff; border-radius:12px; border:1px solid #eee;"></div>
            </div>
        </div>
    </div>

    <div id="dateFilterModal" class="modal">
        <div class="modal-content">
            <h4>Filter Tanggal</h4>
            <div class="form-group">
                <label for="startDate">Dari Tanggal</label>
                <input type="date" id="startDate" class="form-input">
            </div>
            <div class="form-group">
                <label for="endDate">Sampai Tanggal</label>
                <input type="date" id="endDate" class="form-input">
            </div>
            <div class="modal-button-container">
                <button type="button" id="closeDateModalBtn" class="btn btn-secondary">Batal</button>
                <button type="button" id="applyDateFilterBtn" class="btn btn-success">Terapkan</button>
            </div>
        </div>
    </div>

    <div id="txDetailHistoryModal" class="modal">
        <div class="modal-content">
            
            <div style="text-align: center; margin-bottom: 20px;">
                <div id="detailStatusIcon" style="font-size: 3.5rem; margin-bottom: 10px;"></div>
                <h3 style="margin: 0;">Detail Transaksi</h3>
                <p id="detailRefIdHeader" style="color: #888; font-size: 0.9rem; margin-top: 5px; font-family: monospace;"></p>
            </div>

            <hr style="border: 0; border-bottom: 2px dashed var(--border-color-light); margin-bottom: 20px;">

            <ul class="detail-list">
                <li>
                    <dt>Nama Produk</dt>
                    <dd id="detailProductName"></dd>
                </li>
                <li>
                    <dt>Nomor Tujuan</dt>
                    <dd id="detailDestination"></dd>
                </li>
                <li>
                    <dt>Harga</dt>
                    <dd id="detailPrice" style="color: var(--primary-color);"></dd>
                </li>
                <li>
                    <dt>Metode Pembayaran</dt>
                    <dd id="detailPayment"></dd>
                </li>
                <li>
                    <dt>Status</dt>
                    <dd id="detailStatus"></dd>
                </li>
                <li>
                    <dt>SN / Keterangan</dt>
                    <dd id="detailPengelola" style="max-width: 60%; word-wrap: break-word; font-size: 0.85rem;"></dd>
                </li>
                <li>
                    <dt>Waktu</dt>
                    <dd id="detailWaktu" style="font-size: 0.85rem;"></dd>
                </li>
            </ul>

            <div class="modal-button-container">
                <button id="copyTxDetailBtn" class="btn btn-info">
                    <i class="fas fa-copy"></i> Salin
                </button>
                <button id="closeTxDetailHistoryBtn" class="btn btn-danger">
                    Tutup
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- Inisialisasi Elemen DOM ---
            const topupHistoryBody = document.getElementById('topup-history-body');
            const transactionHistoryBody = document.getElementById('transaction-history-body');
            const historyItems = document.querySelectorAll('.history-item');
            
            const historyQrisModal = document.getElementById('historyQrisModal');
            const historyQrisContainer = document.getElementById('historyQrisContainer');
            const dateFilterModal = document.getElementById('dateFilterModal');
            const txDetailHistoryModal = document.getElementById('txDetailHistoryModal');

            const topupSearchInput = document.getElementById('topupSearchInput');
            const txSearchInput = document.getElementById('txSearchInput');
            const startDateInput = document.getElementById('startDate');
            const endDateInput = document.getElementById('endDate');
            
            const topupSearchBtn = document.getElementById('topupSearchBtn');
            const txSearchBtn = document.getElementById('txSearchBtn');
            const topupDateFilterBtn = document.getElementById('topupDateFilterBtn');
            const txDateFilterBtn = document.getElementById('txDateFilterBtn');
            const closeDateModalBtn = document.getElementById('closeDateModalBtn');
            const applyDateFilterBtn = document.getElementById('applyDateFilterBtn');
            
            const copyTxDetailBtn = document.getElementById('copyTxDetailBtn');
            const closeTxDetailHistoryBtn = document.getElementById('closeTxDetailHistoryBtn');

            let currentFilterType = '';

            // --- Helper Functions ---
            const formatCurrency = (amount) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);

            const formatWaktu = (dateString) => {
                if (!dateString) return '-';
                const d = new Date(dateString);
                if (isNaN(d)) return '-';
                const pad = (num) => num.toString().padStart(2, '0');
                return `${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear().toString().slice(-2)}, ${pad(d.getHours())}:${pad(d.getMinutes())}`;
            };

            const maskString = (str) => {
                if (!str || str.length <= 4) return str;
                return '*'.repeat(str.length - 4) + str.slice(-4);
            };

            const getStatusBadge = (status) => {
                status = status ? status.toLowerCase() : 'failed';
                let className = 'status-failed';
                if (status === 'success' || status === 'sukses') className = 'status-success';
                else if (['pending', 'processing'].includes(status)) className = 'status-pending';
                return `<span class="status-badge ${className}">${status.toUpperCase()}</span>`;
            };

            // --- LOGIKA ACCORDION (BUKA-TUTUP) YANG BENAR ---
            historyItems.forEach(item => {
                const header = item.querySelector('.history-header');
                header.addEventListener('click', () => {
                    // 1. Cek apakah item ini sedang aktif
                    const isActive = item.classList.contains('active');
                    
                    // 2. Tutup SEMUA item dulu (agar cuma 1 yang terbuka)
                    historyItems.forEach(otherItem => otherItem.classList.remove('active'));
                    
                    // 3. Jika tadi TIDAK aktif, maka sekarang aktifkan (Buka).
                    //    Jika tadi SUDAH aktif, biarkan tertutup (Toggle Close).
                    if (!isActive) {
                        item.classList.add('active');
                    }
                });
            });

            // --- KLIK DETAIL TRANSAKSI ---
            transactionHistoryBody.addEventListener('click', (e) => {
                // Cek jika tombol view/qris diklik
                if (e.target.closest('.btn-view') || e.target.classList.contains('show-history-qris')) {
                    const btn = e.target.closest('.show-history-qris');
                    if(btn) {
                        const qris = btn.getAttribute('data-qris');
                        if (qris) showHistoryQrisModal(qris);
                    }
                    return; 
                }

                const row = e.target.closest('tr');
                if (!row || !row.dataset.transaction) return;

                const txData = JSON.parse(row.dataset.transaction);
                const status = txData.status ? txData.status.toLowerCase() : 'failed';
                
                let pengelolaText = (status === 'success' || status === 'sukses') 
                    ? (txData.serial_number.slice(-4) || '-') 
                    : (txData.message || '-');

                // Set Icon
                const iconContainer = document.getElementById('detailStatusIcon');
                if (status === 'success' || status === 'sukses') {
                    iconContainer.innerHTML = '<i class="fas fa-check-circle" style="color: #10b981;"></i>';
                } else if (['pending', 'processing'].includes(status)) {
                    iconContainer.innerHTML = '<i class="fas fa-clock" style="color: #f59e0b;"></i>';
                } else {
                    iconContainer.innerHTML = '<i class="fas fa-times-circle" style="color: #ef4444;"></i>';
                }

                // Set Text Content
                document.getElementById('detailRefIdHeader').textContent = `#${txData.ref_id}`;
                document.getElementById('detailProductName').textContent = txData.product_name || '-';
                document.getElementById('detailDestination').textContent = txData.destination || '-';
                document.getElementById('detailPrice').textContent = formatCurrency(txData.price);
                document.getElementById('detailPayment').textContent = txData.payment_method || '-';
                document.getElementById('detailStatus').innerHTML = getStatusBadge(txData.status);
                document.getElementById('detailPengelola').textContent = pengelolaText;
                document.getElementById('detailWaktu').textContent = formatWaktu(txData.updated_at);

                txDetailHistoryModal.style.display = 'block';
            });
            
            // --- FUNGSI COPY ---
            const copyToClipboard = (text) => {
                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(text).then(() => alert('Tersalin!')).catch(() => fallbackCopy(text));
                } else {
                    fallbackCopy(text);
                }
            };

            const fallbackCopy = (text) => {
                const ta = document.createElement("textarea");
                ta.value = text;
                ta.style.position = "fixed";
                document.body.appendChild(ta);
                ta.focus(); ta.select();
                try { document.execCommand('copy'); alert('Tersalin!'); } catch (err) { alert('Gagal salin manual.'); }
                document.body.removeChild(ta);
            };

            copyTxDetailBtn.addEventListener('click', () => {
                const ref = document.getElementById('detailRefIdHeader').textContent;
                const prod = document.getElementById('detailProductName').textContent;
                const dest = document.getElementById('detailDestination').textContent;
                const price = document.getElementById('detailPrice').textContent;
                const stat = document.getElementById('detailStatus').innerText;
                const sn = document.getElementById('detailPengelola').textContent;
                
                const text = `STRUK TRANSAKSI

ID     : ${ref}
Produk : ${prod}
Tujuan : ${dest}
Harga  : ${price}
Status : ${stat}
SN/Ket : ${sn}

Terima Kasih!`;
                copyToClipboard(text);
            });

            // --- FETCH DATA ---
            const fetchHistory = async (type, searchTerm = '', startDate = '', endDate = '') => {
                const endpoint = type === 'topup' ? '/api/history/topups' : '/api/history/transactions';
                const bodyElement = type === 'topup' ? topupHistoryBody : transactionHistoryBody;
                const colSpan = type === 'topup' ? 4 : 6; 
                
                bodyElement.innerHTML = `<tr><td colspan="${colSpan}" style="text-align:center;"><div class="spinner" style="margin:10px auto; width:25px; height:25px;"></div></td></tr>`;
                
                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ searchTerm, startDate, endDate })
                    });
                    const result = await response.json();
                    if (!response.ok || !result.success) throw new Error(result.message);
                    
                    if (type === 'topup') populateTopupHistory(result.data);
                    else populateTransactionHistory(result.data);
                    
                } catch (error) {
                    bodyElement.innerHTML = `<tr><td colspan="${colSpan}" style="text-align:center; color:#ef4444;">Gagal memuat data.</td></tr>`;
                }
            };

            const populateTopupHistory = (topups) => {
                topupHistoryBody.innerHTML = '';
                if (topups.length === 0) {
                    topupHistoryBody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:20px; color:#888;">Belum ada riwayat.</td></tr>';
                    return;
                }
                topups.forEach(topup => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td><small>${topup.top_up_id}</small></td>
                        <td>${formatCurrency(topup.amount)}</td>
                        <td style="text-align:center;">${getStatusBadge(topup.status)}</td>
                        <td><small>${formatWaktu(topup.updated_at)}</small></td>
                    `;
                    topupHistoryBody.appendChild(row);
                });
            };

            const populateTransactionHistory = (transactions) => {
                transactionHistoryBody.innerHTML = '';
                if (transactions.length === 0) {
                    transactionHistoryBody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px; color:#888;">Belum ada transaksi.</td></tr>';
                    return;
                }
                transactions.forEach(tx => {
                    const row = document.createElement('tr');
                    row.classList.add('clickable-row');
                    row.dataset.transaction = JSON.stringify(tx);
                    
                    let snText = (['success', 'sukses'].includes((tx.status||'').toLowerCase())) 
                        ? tx.serial_number.slice(-4) || '' 
                        : (tx.message || '-');

                    row.innerHTML = `
                        <td><small>${tx.ref_id}</small></td>
                        <td>${tx.product_name || '-'}</td>
                        <td>${tx.destination}</td>
                        <td style="color:var(--danger);">${formatCurrency(tx.price)}</td>
                        <td style="text-align:center;">${getStatusBadge(tx.status)}</td>
                        <td><small>${snText}</small></td>
                    `;
                    transactionHistoryBody.appendChild(row);
                });
            };

            // --- Show QRIS Modal ---
            const showHistoryQrisModal = (qrisString) => {
                historyQrisContainer.innerHTML = '';
                if (qrisString.startsWith('data:image')) {
                    const img = document.createElement('img');
                    img.src = qrisString;
                    img.style.maxWidth = '250px';
                    historyQrisContainer.appendChild(img);
                } else {
                    const qr = qrcode(0, 'M'); qr.addData(qrisString); qr.make();
                    historyQrisContainer.innerHTML = qr.createImgTag(6, 0);
                }
                historyQrisModal.style.display = 'block';
            };

            // --- Event Listeners Search/Filter ---
            topupSearchBtn.addEventListener('click', () => fetchHistory('topup', topupSearchInput.value));
            txSearchBtn.addEventListener('click', () => fetchHistory('transaction', txSearchInput.value));
            
            topupDateFilterBtn.addEventListener('click', () => { currentFilterType = 'topup'; dateFilterModal.style.display = 'block'; });
            txDateFilterBtn.addEventListener('click', () => { currentFilterType = 'transaction'; dateFilterModal.style.display = 'block'; });
            closeDateModalBtn.addEventListener('click', () => dateFilterModal.style.display = 'none');
            
            applyDateFilterBtn.addEventListener('click', () => {
                const start = startDateInput.value; const end = endDateInput.value;
                if (!start || !end) return alert('Pilih tanggal.');
                const endD = new Date(end); endD.setHours(23, 59, 59, 999);
                fetchHistory(currentFilterType, currentFilterType==='topup'?topupSearchInput.value:txSearchInput.value, new Date(start).toISOString(), endD.toISOString());
                dateFilterModal.style.display = 'none';
            });

            // --- Tutup Modal ---
            const hideModals = () => {
                dateFilterModal.style.display = 'none';
                txDetailHistoryModal.style.display = 'none';
                historyQrisModal.style.display = 'none';
            };
            
            closeTxDetailHistoryBtn.addEventListener('click', hideModals);
            window.addEventListener('click', (e) => {
                if([dateFilterModal, txDetailHistoryModal, historyQrisModal].includes(e.target)) hideModals();
            });

            // Load Data Awal
            const today = new Date();
            const startOfDay = new Date(today.getFullYear(), today.getMonth(), today.getDate()).toISOString();
            const endOfDay = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59).toISOString();
            fetchHistory('topup', '', startOfDay, endOfDay);
            fetchHistory('transaction', '', startOfDay, endOfDay);
        });
    </script>
    
    <script src="/js/sidebar.js"></script>
    <script src="/js/theme.js"></script>
    <script src="/js/submenu.js"></script>
</body>
</html>
